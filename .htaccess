# ===================================================================
# ATIVAR REWRITE
# ===================================================================
RewriteEngine On

# ===================================================================
# FORÇAR HTTPS E REMOVER WWW
# ===================================================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.prolon-fasten\.shop$ [NC]
RewriteRule ^(.*)$ https://prolon-fasten.shop/$1 [R=301,L]

# ===================================================================
# REMOVER .html DA URL
# ===================================================================

# Redirecionar /pagina.html → /pagina
RewriteCond %{THE_REQUEST} /([^\s/]+)\.html [NC]
RewriteRule ^([^\s/]+)\.html$ /$1 [R=301,L]

# Servir pagina.html quando acessar /pagina
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([a-zA-Z0-9\-]+)/?$ $1.html [L]

# Redirecionar /index.html → /
RewriteCond %{THE_REQUEST} /index\.html [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ===================================================================
# CACHE — REGRAS GERAIS
# ===================================================================

<IfModule mod_expires.c>
    ExpiresActive On

    # HTML — NÃO CACHEAR
    ExpiresByType text/html "access plus 0 seconds"

    # CSS e JS — CACHE MÉDIO
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"

    # Imagens — CACHE LONGO
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fontes — CACHE LONGO
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType font/opentype "access plus 1 year"
</IfModule>

# ===================================================================
# CACHE-CONTROL HEADERS
# ===================================================================

<IfModule mod_headers.c>

    # HTML — NUNCA CACHEAR
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # CSS e JS
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # Imagens
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Fontes
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

</IfModule>

# ===================================================================
# DESATIVAR CACHE DE SERVIDOR (LiteSpeed se existir)
# ===================================================================
<IfModule LiteSpeed>
    CacheDisable public /
</IfModule>